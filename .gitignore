# ══════════════════════════════════════════════════
#  FFP Data Validation — .gitignore
# ══════════════════════════════════════════════════

# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
build/
develop-eggs/
dist/
eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
*.egg

# ── Node / Frontend ──────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
frontend/next-env.d.ts

# ── Environment ──────────────────────────────────
.env
.env.local
.env.*.local
# DO commit these templates:
!.env.example
!.env.production

# ── Runtime data (generated by the app) ──────────
db_data/
db_backups/
downloads/
uploads/
*.log
backend_logs*.txt
backend_debug*.txt
build_output.txt

# ── Database backups / large binary files ────────
*.tar.gz
*.sql.gz
*.dump

# ── Example / test data files ────────────────────
*.xlsx
*.xls

# ── Stale dev scripts (root-level) ───────────────
test*.py
verify_*.py
create_test_file.py
scrape_upazilas.py
parse_local_html.py
check_duplicates.py
clean_and_export.py
count_upz_per_dist.py
bd_geo_scraped.json
upazila_page.html
test_output.txt
test3_out.txt
DEPLOY.sh

# ── Stale dev scripts (backend) ─────────────────
backend/app/_resurrect_live_valid.py
backend/app/main_head.py
backend/check_rbac.py

# ── OS / Editor ──────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.bak
*.tmp
*.temp
.vscode/
.idea/
