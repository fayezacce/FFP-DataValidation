# FFP Data Validation — Production Environment Variables
# Copy this file to .env on the server and fill in real values.
# NEVER commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=ffp_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ffp_validator

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=CHANGE_ME_JWT_SECRET_64_CHARS_MIN

# ── CORS (comma-separated list of allowed origins) ───────────────────────────
# Example: https://ffp.mofood.gov.bd,https://api.ffp.mofood.gov.bd
ALLOWED_ORIGINS=https://your-production-domain.gov.bd

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE=20971520

# ── API Documentation ───────────────────────────────────────────────────────
# Set to "false" to enable /docs endpoint. Keep "true" in production.
DISABLE_DOCS=true

# ── Backup ───────────────────────────────────────────────────────────────────
BACKUP_SCHEDULE=0 2 * * *   # cron: daily at 2 AM UTC
BACKUP_RETENTION_DAYS=30
